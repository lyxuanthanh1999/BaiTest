{
    "name": "NewReactNativeZustandRNQ",
    "version": "0.0.1",
    "private": true,
    "scripts": {
        "android": "npm run check:env && npx expo run:android --variant devDebug --device",
        "android:stg": "npm run check:env && npx expo run:android --variant stagingDebug --app-id com.newreactnativezustandrnq.stg --device",
        "android:prod": "npm run check:env && npx expo run:android --variant productionDebug --app-id com.newreactnativezustandrnq.prod --device",
        "ios": "npm run check:env && npx expo run:ios --device",
        "ios:stg": "npm run check:env && ENVFILE=.env.staging npx expo run:ios --scheme Staging --configuration Staging.Debug --device",
        "ios:prod": "npm run check:env && ENVFILE=.env.production npx expo run:ios --scheme Product --configuration Product.Debug --device",
        "check:env": "node scripts/check-env.js",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "start": "npx expo start",
        "test": "jest",
        "test:ci": "jest --ci --coverage --watchAll=false",
        "clear:expo": "npx expo start --clear",
        "env:push": "dotenv-vault push && dotenv-vault push staging && dotenv-vault push production",
        "env:pull": "dotenv-vault pull && dotenv-vault pull staging && dotenv-vault pull production",
        "env:setup": "node scripts/setup-env.js",
        "adb:reactotron": "adb reverse tcp:9090 tcp:9090",
        "update-versions": "node scripts/update-readme-versions.js",
        "postinstall": "npx lefthook install && node scripts/update-readme-versions.js",
        "doctor": "npx expo-doctor"
    },
